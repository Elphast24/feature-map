{
  "name": "sbatlas",
  "displayName": "SBAtlas",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.123.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:sbatlas.helloWorld"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "SBAtlas",
      "properties": {
        "sbatlas.openaiApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Your OpenAI API key for roadmap generation. Get one at https://platform.openai.com/api-keys",
          "order": 1
        },
        "sbatlas.openaiModel": {
          "type": "string",
          "default": "gpt-4o-mini",
          "markdownDescription": "The OpenAI model to use. `gpt-4o-mini` is recommended for cost efficiency.",
          "order": 2
        },
        "sbatlas.maxTokens": {
          "type": "number",
          "default": 4096,
          "markdownDescription": "Maximum tokens in the AI response. Increase for projects with many requirements.",
          "order": 3
        }
      }
    },
    "commands": [
      { "command": "sbatlas.createProject", "title": "Create Project", "category": "SBAtlas" },
      { "command": "sbatlas.deleteProject", "title": "Delete Project", "category": "SBAtlas" },
      { "command": "sbatlas.pasteRequirement", "title": "Add Requirement", "category": "SBAtlas" },
      { "command": "sbatlas.editRequirement", "title": "Edit Requirement", "category": "SBAtlas" },
      { "command": "sbatlas.refresh", "title": "Refresh", "category": "SBAtlas" },
      { "command": "sbatlas.generateRoadmap", "title": "Generate Roadmap", "category": "SBAtlas" },
      { "command": "sbatlas.updateTaskStatus", "title": "Update Task Status", "category": "SBAtlas" },
      { "command": "sbatlas.addTaskNote", "title": "Add Task Note", "category": "SBAtlas" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sbatlas-sidebar",
          "title": "SBAtlas",
          "icon": "resources/icons/sbatlas.svg"
        }
      ]
    },
    "views": {
      "sbatlas-sidebar": [
        {
          "id": "sbatlasProjectView",
          "name": "Project",
          "icon": "resources/icons/sbatlas.svg",
          "contextualTitle": "SBAtlas"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "sbatlas.createProject",
          "when": "view == sbatlasProjectView",
          "group": "navigation"
        },
        {
          "command": "sbatlas.refresh",
          "when": "view == sbatlasProjectView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "sbatlas.pasteRequirement",
          "when": "view == sbatlasProjectView && viewItem == requirementsSection",
          "group": "inline"
        },
        {
          "command": "sbatlas.editRequirement",
          "when": "view == sbatlasProjectView && viewItem == requirementItem",
          "group": "inline"
        },
        {
          "command": "sbatlas.deleteProject",
          "when": "view == sbatlasProjectView && viewItem == projectRoot",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.123.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "esbuild": "^0.28.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
